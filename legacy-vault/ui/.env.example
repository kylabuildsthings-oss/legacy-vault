# Legacy Vault UI — environment
# Copy to .env.local for full-stack live Canton mode (recommended for demos and judging).

# Live Canton mode (recommended): backend API + Canton sandbox required.
# Terminal 1: ./scripts/dev-ledger.sh
# Terminal 2: ./scripts/dev-api.sh
# Terminal 3: ./scripts/dev-ui.sh
VITE_USE_MOCK_LEDGER=false

# Developer fallback — UI-only demo with mock fixtures (no Canton/backend required).
# Uncomment to use fixture data instead of live ledger:
# VITE_USE_MOCK_LEDGER=true

# Product backend API (default: http://localhost:4000)
# VITE_LEGACY_VAULT_API=http://localhost:4000

# Daml JSON API URL (optional).
# Default (recommended for dev): leave blank — Vite proxies /v1 → http://localhost:7575 (no CORS).

# Sandbox participant id (default for daml start)
VITE_DAML_LEDGER_ID=sandbox

# Dev JWT HMAC secret for local JSON API tokens (sandbox only)
VITE_DAML_JWT_SECRET=secret
